# ─── Shared ──────────────────────────────────────────────────────────────────
APP_ENV=development

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── Database (used by mining service for direct read-only connection) ────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grademap

# ─── API Gateway ─────────────────────────────────────────────────────────────
PORT=4000
MINING_BASE_URL=http://mining:8000
MINING_SHARED_SECRET=change-me-in-production
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Mining Service ──────────────────────────────────────────────────────────
MINING_PORT=8000

# ─── Web (Vite) ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── K-Anonymity ─────────────────────────────────────────────────────────────
# Minimum number of students required before aggregate data is exposed
K_ANONYMITY_THRESHOLD=10
